{
  "roles": {
    "admin": {
      "description": "Platform administrators with full system access",
      "actor_type": "internal",
      "inherits": ["customer_service", "seller", "transfer", "finance"],
      "permissions": {
        "users": ["read", "write", "delete"],
        "products": ["read", "write", "delete"],
        "orders": ["read", "write", "delete", "cancel"],
        "payments": ["read", "write", "refund", "adjust"],
        "inventory": ["read", "write", "adjust"],
        "analytics": ["read"],
        "system": ["read", "write", "configure"],
        "sellers": ["read", "write", "delete"],
        "employees": ["read", "write", "delete"],
        "schedules": ["read", "write", "delete"],
        "payroll": ["read", "write", "process"],
        "financial_reports": ["read"],
        "shipments": ["read", "write"],
        "transfers": ["read", "write"],
        "cart": ["read", "write"],
        "reviews": ["read", "write", "delete"],
        "support_tickets": ["read", "write", "resolve"]
      }
    },
    "finance": {
      "description": "Financial staff handling payroll, payments, and financial operations",
      "actor_type": "internal",
      "permissions": {
        "payroll": ["read", "write", "process"],
        "payments": ["read", "refund", "adjust"],
        "employees": ["read:financial"],
        "financial_reports": ["read"],
        "analytics": ["read:financial"],
        "tax_info": ["read", "write"]
      }
    },
    "customer_service": {
      "description": "Customer service staff handling inquiries and support",
      "actor_type": "internal",
      "permissions": {
        "users": ["read", "write"],
        "sellers": ["read", "write"],
        "orders": ["read"],
        "support_tickets": ["read", "write", "resolve"],
        "schedules": ["read:own", "write:own"],
        "reviews": ["read", "respond"]
      }
    },
    "seller": {
      "description": "Product sellers who can manage their inventory and view sales",
      "actor_type": "business",
      "permissions": {
        "products": ["read:own", "write:own", "delete:own"],
        "orders": ["read:own"],
        "analytics": ["read:own"],
        "inventory": ["read:own", "write:own"]
      }
    },
    "transfer": {
      "description": "Inventory transfer operators managing stock movements",
      "actor_type": "internal",
      "permissions": {
        "inventory": ["read", "write", "import", "export"],
        "transfers": ["read", "write"],
        "products": ["read", "write:stock"],
        "shipments": ["read", "write", "note"]
      }
    },
    "customer": {
      "description": "Regular platform users with shopping capabilities",
      "actor_type": "external",
      "permissions": {
        "products": ["read"],
        "cart": ["read:own", "write:own"],
        "orders": ["read:own", "write:own"],
        "payments": ["write:own"],
        "reviews": ["read", "write:own"],
        "wishlist": ["read:own", "write:own"],
        "addresses": ["read:own", "write:own"],
        "account": ["read:own", "write:own", "delete:own"]
      }
    }
  },
  "permission_hierarchy": {
    "admin": ["customer_service", "finance", "seller", "transfer", "customer"],
    "finance": ["customer"],
    "customer_service": ["customer"],
    "seller": ["customer"],
    "transfer": [],
    "customer": []
  }
}
