@app.get("/api/cart", response_model=CartResponse, tags=["Cart"])
async def get_cart(
    request: Request,
    current_user=Depends(get_current_active_user),
    db: AsyncSession = Depends(get_db)
):
    """
    Get user's shopping cart.
    
    Security: Requires authentication
    """
