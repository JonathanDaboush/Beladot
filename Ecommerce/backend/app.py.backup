    cart_service = CartService(db)
    cart = await cart_service.get_or_create_cart(current_user.id)
    
    return cart


@app.post("/api/cart/items", response_model=MessageResponse, tags=["Cart"])
async def add_to_cart(
    item: AddToCartRequest,
    request: Request,
    current_user=Depends(get_current_active_user),
    db: AsyncSession = Depends(get_db)
):
    """
    Add item to cart.
    
    Security:
    - Requires authentication
    - CSRF protection
    - Input validation
    """
    await rate_limiter_moderate.check_rate_limit(request)
    
    cart_service = CartService(db)
    await cart_service.add_item(
        user_id=current_user.id,
        product_variant_id=item.product_variant_id,
        quantity=item.quantity
    )
    
    return MessageResponse(message="Item added to cart successfully")


