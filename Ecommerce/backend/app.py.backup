@app.post("/api/employee/clock-in", response_model=MessageResponse, tags=["Employee"])
async def clock_in(
    request: Request,
    employee=Depends(get_current_employee),
    db: AsyncSession = Depends(get_db)
):
    """
    Clock in for shift.
    
    Security: Employee, seller (if also employee), or admin access required
    """
    await rate_limiter_moderate.check_rate_limit(request)
    
    from Services.TimeTrackingService import TimeTrackingService
    time_service = TimeTrackingService(db)
    
    # Get employee_id from Employee table (linked to user)
    from Repositories.EmployeeRepository import EmployeeRepository
    employee_repo = EmployeeRepository(db)
    employee_record = await employee_repo.get_by_user_id(employee.id)
    
    if not employee_record:
        raise HTTPException(
            status_code=status.HTTP_404_NOT_FOUND,
            detail="Employee record not found. Contact admin."
        )
    
    await time_service.clock_in(employee_record.id)
    logger.info(f"Employee {employee_record.id} clocked in")
    
    return MessageResponse(message="Clocked in successfully")


@app.post("/api/employee/clock-out", response_model=MessageResponse, tags=["Employee"])
async def clock_out(
    break_minutes: int = 0,
    request: Request = None,
    employee=Depends(get_current_employee),
    db: AsyncSession = Depends(get_db)
):
    """
    Clock out from shift.
    
    Security: Employee, seller (if also employee), or admin access required
    """
    await rate_limiter_moderate.check_rate_limit(request)
    
    from Services.TimeTrackingService import TimeTrackingService
    time_service = TimeTrackingService(db)
    
    from Repositories.EmployeeRepository import EmployeeRepository
    employee_repo = EmployeeRepository(db)
    employee_record = await employee_repo.get_by_user_id(employee.id)
    
    if not employee_record:
        raise HTTPException(
            status_code=status.HTTP_404_NOT_FOUND,
            detail="Employee record not found"
        )
    
    await time_service.clock_out(employee_record.id, break_minutes)
    logger.info(f"Employee {employee_record.id} clocked out")
    
    return MessageResponse(message="Clocked out successfully")


