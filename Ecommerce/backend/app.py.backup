@app.get("/api/products", tags=["Products"])
async def list_products(
    request: Request,
    page: int = 1,
    page_size: int = 20,
    db: AsyncSession = Depends(get_db)
):
    """
    List products (public endpoint).
    
    Security: Rate limited
    """
    await rate_limiter_moderate.check_rate_limit(request)
    
    # Validate pagination
    pagination = PaginationParams(page=page, page_size=page_size)
    
    product_repo = ProductRepository(db)
    products = await product_repo.get_all(
        offset=pagination.offset,
        limit=pagination.page_size
    )
    
    return {"products": products, "page": page, "page_size": page_size}


@app.post("/api/products", response_model=ProductResponse, tags=["Products"])
async def create_product(
    product_data: ProductCreateRequest,
    request: Request,
    seller=Depends(get_current_seller),  # Changed: Sellers can create products
    db: AsyncSession = Depends(get_db)
):
    """
    Create new product (seller or admin).
    
    Security:
    - Seller or admin authentication required
    - Input validation
    - CSRF protection
    """
    await rate_limiter_moderate.check_rate_limit(request)
    
    product_service = ProductService(db)
    new_product = await product_service.create_product(
        name=sanitize_string(product_data.name),
        description=sanitize_string(product_data.description),
        price=product_data.price,
        cost=product_data.cost,
        sku=product_data.sku,
        category_id=product_data.category_id,
        seller_id=product_data.seller_id,
        stock_quantity=product_data.stock_quantity
    )
    
    logger.info(f"Product created by {seller.role} {seller.id}: {new_product.name}")
    
    return new_product


